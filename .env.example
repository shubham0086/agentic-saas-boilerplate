# ── Billing Webhook Secrets ───────────────────────────────────────────────────
# Stripe: get from https://dashboard.stripe.com/webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# Razorpay: get from https://dashboard.razorpay.com/app/webhooks → Secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# ── Backend Server ────────────────────────────────────────────────────────────
# Port for FastAPI (default: 8000)
BACKEND_PORT=8000

# ── Optional: LLM Provider Keys (for real agent execution) ───────────────────
# Uncomment and fill when wiring in actual LLM calls (dag_engine.py Node.execute)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIza...

# ── Optional: Redis (for production queue, not required for demo) ─────────────
# REDIS_URL=redis://localhost:6379
